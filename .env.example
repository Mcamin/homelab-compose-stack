########################################
# Global / shared configuration  ->  copy to ./.env
#
# Each stack documents ITS variables in stacks/<category>/<service>/.env.example.
# Add the ones you need into THIS single .env (every stack reads ../../../.env).
########################################

TZ=Europe/Berlin
PUID=1000
PGID=1000

# Base paths on the host
CONFIG_ROOT=/srv/homelab/config
DATA_ROOT=/srv/homelab/data
MEDIA_ROOT=/srv/media
DOWNLOADS_ROOT=/srv/downloads

# External Docker networks (create once):
#   docker network create homelab_shared
#   docker network create homelab_proxy
SHARED_NETWORK=homelab_shared
PROXY_NETWORK=homelab_proxy

# Reverse proxy / TLS (used by the commented Traefik labels)
TRAEFIK_CERTRESOLVER=letsencrypt
