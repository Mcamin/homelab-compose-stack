########################################
# Global Settings
########################################

TZ=Europe/Berlin
PUID=1000
PGID=1000

########################################
# Base Paths
########################################

# Root directories on host
CONFIG_ROOT=/srv/homelab/config
DATA_ROOT=/srv/homelab/data

# Media-specific paths
MEDIA_ROOT=/srv/media
DOWNLOADS_ROOT=/srv/downloads

########################################
# Network Configuration
########################################

# Shared internal network
SHARED_NETWORK=homelab_shared

# Reverse proxy network (optional, for Traefik/Nginx)
PROXY_NETWORK=homelab_proxy

########################################
# Domain / Access (optional)
########################################

# Base domain (used for reverse proxy setups)
BASE_DOMAIN=home.local

# Example subdomains (optional usage)
JELLYFIN_DOMAIN=jellyfin.home.local
RADARR_DOMAIN=radarr.home.local
SONARR_DOMAIN=sonarr.home.local

########################################
# Ports (fallback if not using proxy)
########################################

JELLYFIN_PORT=8096
RADARR_PORT=7878
SONARR_PORT=8989
PORTAINER_PORT=9000
UPTIME_KUMA_PORT=3001

########################################
# Service-Specific Settings
########################################

# Jellyfin
JELLYFIN_CONFIG=${CONFIG_ROOT}/jellyfin

# Radarr
RADARR_CONFIG=${CONFIG_ROOT}/radarr
RADARR_MOVIES=${MEDIA_ROOT}/movies

# Sonarr
SONARR_CONFIG=${CONFIG_ROOT}/sonarr
SONARR_TV=${MEDIA_ROOT}/tv

########################################
# Development / Debug
########################################

# Enable debug logs (if supported by services)
DEBUG=false