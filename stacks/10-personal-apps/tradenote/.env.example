TRADENOTE_DOMAIN=tradenote.local.example.com
TRADENOTE_PORT=8082

# Needs the 06-databases/mongodb stack (or any Mongo). Adjust user/pass/host.
TRADENOTE_MONGO_URI=mongodb://root:change-me@mongodb:27017/tradenote?authSource=admin
TRADENOTE_DATABASE=tradenote

# Parse server app id + master key (any random strings you choose)
TRADENOTE_APP_ID=change-me
TRADENOTE_MASTER_KEY=change-me

TRAEFIK_CERTRESOLVER=letsencrypt
