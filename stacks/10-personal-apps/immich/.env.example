########################################
# Immich (photo/video backup: server + ML + Redis + Postgres)
########################################

IMMICH_DOMAIN=immich.local.example.com
IMMICH_PORT=2283

# Where your photos/videos are stored on the host
IMMICH_UPLOAD_LOCATION=/srv/immich/library

# Database (change-me)
IMMICH_DB_NAME=immich
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=change-me

TRAEFIK_CERTRESOLVER=letsencrypt
