########################################
# Gluetun VPN — the network gateway for the arr download stacks
########################################

GLUETUN_VPN_PROVIDER=custom
GLUETUN_VPN_TYPE=wireguard

# Your VPN provider's WireGuard details — CHANGE THESE.
GLUETUN_WIREGUARD_PRIVATE_KEY=change-me
GLUETUN_WIREGUARD_ADDRESSES=10.x.x.x/32

GLUETUN_SERVER_COUNTRIES=Netherlands

# Your LAN subnet, so you can reach the published web UIs from other devices.
GLUETUN_LAN_SUBNET=192.168.1.0/24

# Published UI ports (uncomment the matching lines in gluetun/compose.yml too)
QBITTORRENT_PORT=8080
NZBGET_PORT=6789
SONARR_PORT=8989
RADARR_PORT=7878
LIDARR_PORT=8686
BAZARR_PORT=6767
PROWLARR_PORT=9696
JACKETT_PORT=9117
FLARESOLVERR_PORT=8191
SEERR_PORT=5055
BINDERY_PORT=8787
OPENBOOKS_PORT=8090
DISPATCHARR_PORT=9191
CWA_PORT=8083
