########################################
# Tugtainer (web-UI container updater)
########################################

TUGTAINER_DOMAIN=tugtainer.local.example.com

# Shared secret for the backend<->agent channel — CHANGE THIS.
TUGTAINER_AGENT_SECRET=change-me

# Host port for the web UI (maps to container :80)
TUGTAINER_PORT=9412

TRAEFIK_CERTRESOLVER=letsencrypt
