SEMAPHORE_DOMAIN=semaphore.local.example.com
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@example.com
SEMAPHORE_ADMIN_PASSWORD=change-me
# 32-byte base64 key. Generate: head -c32 /dev/urandom | base64
SEMAPHORE_ACCESS_KEY_ENCRYPTION=change-me
SEMAPHORE_PORT=3000
TRAEFIK_CERTRESOLVER=letsencrypt
