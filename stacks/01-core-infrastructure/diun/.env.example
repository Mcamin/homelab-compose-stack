########################################
# Diun (image-update NOTIFICATIONS only — it never updates anything)
########################################

# How often to check (cron). Default every 6 hours.
DIUN_WATCH_SCHEDULE=0 */6 * * *

# Optional ntfy notifications (leave endpoint blank to disable)
DIUN_NTFY_ENDPOINT=
DIUN_NTFY_TOPIC=diun
