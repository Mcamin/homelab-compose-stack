INFISICAL_DOMAIN=infisical.local.example.com
INFISICAL_PORT=8080

# 16-byte hex. Generate: openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=change-me
# 32-byte base64. Generate: openssl rand -base64 32
INFISICAL_AUTH_SECRET=change-me

INFISICAL_DB_USER=infisical
INFISICAL_DB_PASSWORD=change-me
INFISICAL_DB_NAME=infisical

TRAEFIK_CERTRESOLVER=letsencrypt
