########################################
# Vaultwarden (Bitwarden-compatible)
########################################

VAULTWARDEN_DOMAIN=vault.local.example.com

# Admin page token — CHANGE THIS. Generate with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=change-me

# Allow new account sign-ups. Set to false after creating your account(s).
VAULTWARDEN_SIGNUPS_ALLOWED=false

# Host port for the web vault (maps to container :80)
VAULTWARDEN_PORT=8081

TRAEFIK_CERTRESOLVER=letsencrypt
