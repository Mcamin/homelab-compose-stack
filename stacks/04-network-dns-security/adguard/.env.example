########################################
# AdGuard Home
########################################

ADGUARD_DOMAIN=adguard.local.example.com

# First-run setup wizard port (http://<host>:3000). Used only until setup is done.
ADGUARD_SETUP_PORT=3000

# Host port for the admin web UI after setup (maps to container :80)
ADGUARD_WEB_PORT=8080

TRAEFIK_CERTRESOLVER=letsencrypt
