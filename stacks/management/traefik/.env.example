########################################
# Traefik / ACME
########################################

TRAEFIK_DOMAIN=traefik.example.local
TRAEFIK_CERTRESOLVER=letsencrypt
ACME_EMAIL=admin@example.com

# Optional: dashboard basic auth
# Generate with: htpasswd -nb username password
TRAEFIK_BASIC_AUTH=admin:$$apr1$$replace_this_hash

########################################
# Cloudflare DNS Challenge (optional)
########################################

# Token with DNS edit permissions
# CF_DNS_API_TOKEN=your_cloudflare_dns_api_token

# Optional separate token with Zone read permissions
# CF_ZONE_API_TOKEN=your_cloudflare_zone_api_token